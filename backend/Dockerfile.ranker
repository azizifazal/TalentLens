FROM public.ecr.aws/lambda/python:3.12

# requirements.txt is at the root of the build context (backend/)
COPY requirements.txt ${LAMBDA_TASK_ROOT}/
RUN pip install --no-cache-dir -r ${LAMBDA_TASK_ROOT}/requirements.txt

# Copy all backend source code into backend/ subdir inside the Lambda task root
# so Python imports resolve as "backend.workers.ranker_worker", etc.
COPY . ${LAMBDA_TASK_ROOT}/backend/

CMD ["backend.workers.ranker_worker.handler"]
